rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token != null && request.auth.token.email == 'micaelcorreiademelo@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isAdmin() || resource.data.role == 'TRAINER' || resource.data.trainerId == request.auth.uid || resource.data.email == request.auth.token.email);
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      // Standard update for owners and admins
      allow update: if (isOwner(userId) || isAdmin()) && (
        isValidUser(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'phone', 'birthdate', 'bio', 'specialty', 'onboardingCompleted', 'role', 'status', 'plan', 'createdAt', 'updatedAt', 'trainerId', 'trainerCode', 'studentsCount', 'username', 'financialSettings', 'notifications', 'privacy']) && 
        (isAdmin() || incoming().role == existing().role)
      );

      // Specific update for trainers managing their students
      allow update: if isTrainerApproving(userId) || isTrainerManagingStudent(userId);
      
      allow delete: if isOwner(userId) || isAdmin();

      function isValidUser(data) {
        return data.keys().hasAll(['id', 'name', 'email', 'role']) &&
               data.id == userId &&
               (isAdmin() || data.email == request.auth.token.email || (resource != null && data.email == resource.data.email)) &&
               data.role in ['ADMIN', 'TRAINER', 'STUDENT'] &&
               data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
               (!('username' in data) || (data.username is string && data.username.size() <= 50)) &&
               (!('bio' in data) || (data.bio is string && data.bio.size() <= 1000)) &&
               (!('specialty' in data) || (data.specialty is string && data.specialty.size() <= 200)) &&
               (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 1000)) &&
               (!('phone' in data) || (data.phone is string && data.phone.size() <= 50)) &&
               (!('birthdate' in data) || (data.birthdate is string && data.birthdate.size() <= 20)) &&
               (!('financialSettings' in data) || data.financialSettings is map) &&
               (!('notifications' in data) || data.notifications is map) &&
               (!('privacy' in data) || data.privacy is map) &&
               (!('expDate' in data) || data.expDate is string) &&
               (!('subscriptionExpiry' in data) || data.subscriptionExpiry is string || data.subscriptionExpiry == null);
      }

      function isTrainerApproving(targetStudentId) {
        return isSignedIn() && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TRAINER' &&
               incoming().trainerId == request.auth.uid &&
               incoming().diff(existing()).affectedKeys().hasOnly(['trainerId', 'updatedAt', 'trialUntil']);
      }

      function isTrainerManagingStudent(targetStudentId) {
        return isSignedIn() &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TRAINER' &&
               existing().trainerId == request.auth.uid &&
               incoming().diff(existing()).affectedKeys().hasOnly(['trialUntil', 'updatedAt', 'plan', 'expDate', 'status', 'subscriptionExpiry', 'trainerId']) &&
               (incoming().get('trainerId', null) == existing().trainerId || incoming().get('trainerId', null) == null);
      }
    }



    // --- Workouts ---
    match /workouts/{workoutId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.trainerId == request.auth.uid || resource.data.studentId == request.auth.uid || (request.auth.uid in resource.data.studentIds)));
      allow create: if isSignedIn() && (isAdmin() || incoming().trainerId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || existing().trainerId == request.auth.uid);
      allow delete: if isSignedIn() && (isAdmin() || existing().trainerId == request.auth.uid);
    }

    // --- Agenda Events ---
    match /agendaEvents/{eventId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.trainerId == request.auth.uid));
      allow create: if isSignedIn() && (isAdmin() || incoming().trainerId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || existing().trainerId == request.auth.uid);
      allow delete: if isSignedIn() && (isAdmin() || existing().trainerId == request.auth.uid);
    }


    // --- Link Requests ---
    match /linkRequests/{requestId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.studentId == request.auth.uid || resource.data.trainerId == request.auth.uid);
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid && isValidLinkRequest(incoming());
      allow update: if isSignedIn() && (
        (existing().studentId == request.auth.uid && incoming().status == 'cancelled') ||
        (existing().trainerId == request.auth.uid && incoming().status in ['approved', 'rejected'])
      ) && isValidLinkRequest(incoming());
      allow delete: if isAdmin();

      function isValidLinkRequest(data) {
        return data.keys().hasAll(['studentId', 'trainerId', 'status']) &&
               isValidId(data.studentId) &&
               isValidId(data.trainerId) &&
               data.status in ['pending', 'approved', 'rejected', 'cancelled'] &&
               (!('studentName' in data) || (data.studentName is string && data.studentName.size() < 100));
      }
    }

    // --- Chats ---
    match /chats/{chatId} {
      allow get: if isSignedIn() && (isAdmin() || chatId.matches(".*" + request.auth.uid + ".*"));
      allow list: if isSignedIn() && (isAdmin() || resource.data.trainerId == request.auth.uid || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || incoming().trainerId == request.auth.uid || incoming().studentId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || existing().trainerId == request.auth.uid || existing().studentId == request.auth.uid);
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/chats/$(chatId)).data.trainerId == request.auth.uid || get(/databases/$(database)/documents/chats/$(chatId)).data.studentId == request.auth.uid);
        allow create: if isSignedIn() && (isAdmin() || incoming().senderId == request.auth.uid);
      }
    }

    // --- Progress ---
    match /progress/{progressId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.studentId == request.auth.uid || resource.data.trainerId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || incoming().studentId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || existing().studentId == request.auth.uid);
      allow delete: if isSignedIn() && (isAdmin() || existing().studentId == request.auth.uid);
    }
    // --- Platform Plans ---
    match /platformPlans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Support Tickets ---
    match /supportTickets/{ticketId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }
    // --- Settings ---
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Security ---
    match /securityPolicies/{policyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /securityLogs/{logId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /loginHistory/{logId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /systemChanges/{changeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /blockedEntities/{entityId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Announcements ---
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Landing Pages ---
    match /landingPages/{username} {
      allow read: if true; // Public access
      allow write: if isSignedIn() && (isAdmin() || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == username));
    }
  }
}
