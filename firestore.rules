rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token != null && request.auth.token.email == 'micaelcorreiademelo@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    function isTrainer() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TRAINER'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isAdmin() || 
        ('role' in resource.data && resource.data.role == 'TRAINER') || 
        ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid) || 
        ('email' in resource.data && resource.data.email == request.auth.token.email)
      );
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().keys().hasAll(['id', 'name', 'email', 'role']);
      
      // Standard update for owners and admins
      allow update: if (isOwner(userId) || isAdmin()) && (
        isValidUser(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'phone', 'birthdate', 'bio', 'specialty', 'onboardingCompleted', 'role', 'status', 'plan', 'createdAt', 'updatedAt', 'trainerId', 'trainerCode', 'studentsCount', 'username', 'financialSettings', 'notifications', 'privacy', 'isOnline', 'lastActive', 'subscriptionExpiry', 'paymentStatus', 'weight', 'height', 'activePlan', 'trialUntil', 'expDate']) && 
        (isAdmin() || (incoming().get('role', '') == existing().get('role', '')))
      );

      // Specific update for trainers managing their students
      allow update: if isTrainerApproving(userId) || isTrainerManagingStudent(userId);
      
      allow delete: if isOwner(userId) || isAdmin();

      function isValidUser(data) {
        return (!('id' in data) || data.id == userId) &&
               (!('email' in data) || (isAdmin() || data.email == request.auth.token.email || (resource != null && 'email' in resource.data && data.email == resource.data.email))) &&
               (!('role' in data) || data.role in ['ADMIN', 'TRAINER', 'STUDENT']) &&
               (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() < 100)) &&
               (!('username' in data) || data.username == null || (data.username is string && data.username.size() <= 50)) &&
               (!('bio' in data) || data.bio == null || (data.bio is string && data.bio.size() <= 1000)) &&
               (!('specialty' in data) || data.specialty == null || (data.specialty is string && data.specialty.size() <= 200)) &&
               (!('avatar' in data) || data.avatar == null || (data.avatar is string && data.avatar.size() <= 10000000)) &&
               (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() <= 50)) &&
               (!('birthdate' in data) || data.birthdate == null || (data.birthdate is string && data.birthdate.size() <= 20)) &&
               (!('financialSettings' in data) || data.financialSettings == null || data.financialSettings is map) &&
               (!('notifications' in data) || data.notifications == null || data.notifications is map) &&
               (!('privacy' in data) || data.privacy == null || data.privacy is map) &&
               (!('expDate' in data) || data.expDate == null || data.expDate is string) &&
               (!('trialUntil' in data) || data.trialUntil == null || data.trialUntil is timestamp || data.trialUntil is string) &&
               (!('activePlan' in data) || data.activePlan == null || data.activePlan is string) &&
               (!('weight' in data) || data.weight == null || data.weight is string || data.weight is number) &&
               (!('height' in data) || data.height == null || data.height is string || data.height is number) &&
               (!('subscriptionExpiry' in data) || data.subscriptionExpiry == null || data.subscriptionExpiry is string) &&
               (!('paymentStatus' in data) || data.paymentStatus == null || data.paymentStatus is string) &&
               (!('isOnline' in data) || data.isOnline == null || data.isOnline is bool) &&
               (!('lastActive' in data) || data.lastActive == null || data.lastActive is timestamp);
      }

      function isTrainerApproving(targetStudentId) {
        return isSignedIn() && 
               ('role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TRAINER') &&
               ('trainerId' in incoming() && incoming().trainerId == request.auth.uid) &&
               incoming().diff(existing()).affectedKeys().hasOnly(['trainerId', 'updatedAt', 'trialUntil']);
      }

      function isTrainerManagingStudent(targetStudentId) {
        return isSignedIn() &&
               ('role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TRAINER') &&
               ('trainerId' in existing() && existing().trainerId == request.auth.uid) &&
               incoming().diff(existing()).affectedKeys().hasOnly(['trialUntil', 'updatedAt', 'plan', 'expDate', 'status', 'subscriptionExpiry', 'trainerId']) &&
               (incoming().get('trainerId', null) == existing().get('trainerId', null) || incoming().get('trainerId', null) == null);
      }
    }



    // --- Workouts ---
    match /workouts/{workoutId} {
      allow read: if isAdmin() || (isSignedIn() && (
        ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid) || 
        ('studentId' in resource.data && resource.data.studentId == request.auth.uid) || 
        ('studentIds' in resource.data && (request.auth.uid in resource.data.studentIds || resource.data.studentIds.hasAny([request.auth.uid])))
      ));
      allow create: if isSignedIn() && (isAdmin() || ('trainerId' in request.resource.data && request.resource.data.trainerId == request.auth.uid));
      allow update: if isSignedIn() && (isAdmin() || 
        ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid) || 
        ('studentId' in resource.data && resource.data.studentId == request.auth.uid) || 
        ('studentIds' in resource.data && (request.auth.uid in resource.data.studentIds || resource.data.studentIds.hasAny([request.auth.uid])))
      );
      allow delete: if isSignedIn() && (isAdmin() || ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid));
    }

    // --- Exercises ---
    match /exercises/{exerciseId} {
      allow read: if isSignedIn() && (isAdmin() || 
        ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid) || 
        ('studentId' in resource.data && resource.data.studentId == request.auth.uid)
      );
      allow create: if isSignedIn() && (isAdmin() || ('trainerId' in request.resource.data && request.resource.data.trainerId == request.auth.uid));
      allow update: if isSignedIn() && (isAdmin() || ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid));
      allow delete: if isSignedIn() && (isAdmin() || ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid));
    }

    // --- Agenda Events ---
    match /agendaEvents/{eventId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.trainerId == request.auth.uid));
      allow create: if isSignedIn() && (isAdmin() || incoming().trainerId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || existing().trainerId == request.auth.uid);
      allow delete: if isSignedIn() && (isAdmin() || existing().trainerId == request.auth.uid);
    }


    // --- Link Requests ---
    match /linkRequests/{requestId} {
      allow read: if isSignedIn() && (isAdmin() || 
        ('studentId' in resource.data && resource.data.studentId == request.auth.uid) || 
        ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid)
      );
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid && isValidLinkRequest(incoming());
      allow update: if isSignedIn() && (
        ('studentId' in existing() && existing().studentId == request.auth.uid && incoming().status == 'cancelled') ||
        ('trainerId' in existing() && existing().trainerId == request.auth.uid && incoming().status in ['approved', 'rejected'])
      ) && isValidLinkRequest(incoming());
      allow delete: if isAdmin();

      function isValidLinkRequest(data) {
        return data.keys().hasAll(['studentId', 'trainerId', 'status']) &&
               isValidId(data.studentId) &&
               isValidId(data.trainerId) &&
               data.status in ['pending', 'approved', 'rejected', 'cancelled'] &&
               (!('studentName' in data) || (data.studentName is string && data.studentName.size() < 100));
      }
    }

    // --- Chats ---
    match /chats/{chatId} {
      allow get: if isSignedIn() && (isAdmin() || chatId.matches(".*" + request.auth.uid + ".*"));
      allow list: if isSignedIn() && (isAdmin() || 
        ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid) || 
        ('studentId' in resource.data && resource.data.studentId == request.auth.uid)
      );
      allow create: if isSignedIn() && (isAdmin() || 
        ('trainerId' in incoming() && incoming().trainerId == request.auth.uid) || 
        ('studentId' in incoming() && incoming().studentId == request.auth.uid)
      );
      allow update: if isSignedIn() && (isAdmin() || 
        ('trainerId' in existing() && existing().trainerId == request.auth.uid) || 
        ('studentId' in existing() && existing().studentId == request.auth.uid)
      );
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (isAdmin() || 
          ('trainerId' in get(/databases/$(database)/documents/chats/$(chatId)).data && get(/databases/$(database)/documents/chats/$(chatId)).data.trainerId == request.auth.uid) || 
          ('studentId' in get(/databases/$(database)/documents/chats/$(chatId)).data && get(/databases/$(database)/documents/chats/$(chatId)).data.studentId == request.auth.uid)
        );
        allow create: if isSignedIn() && (isAdmin() || ('senderId' in incoming() && incoming().senderId == request.auth.uid));
      }
    }

    // --- Assessments ---
    match /assessments/{assessmentId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid) ||
        ('studentId' in resource.data && resource.data.studentId == request.auth.uid)
      );
      allow create: if isSignedIn() && (
        isAdmin() || 
        ('trainerId' in request.resource.data && request.resource.data.trainerId == request.auth.uid) ||
        ('studentId' in request.resource.data && request.resource.data.studentId == request.auth.uid)
      );
      allow update: if isSignedIn() && (
        isAdmin() || 
        ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid) ||
        ('studentId' in resource.data && resource.data.studentId == request.auth.uid)
      );
      allow delete: if isSignedIn() && (
        isAdmin() || 
        ('trainerId' in resource.data && resource.data.trainerId == request.auth.uid)
      );
    }

    // --- Progress ---
    match /progress/{progressId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isTrainer() || 
        ('studentId' in resource.data && resource.data.studentId == request.auth.uid)
      );
      allow create: if isSignedIn() && (isAdmin() || ('studentId' in request.resource.data && request.resource.data.studentId == request.auth.uid));
      allow update: if isSignedIn() && (isAdmin() || ('studentId' in resource.data && resource.data.studentId == request.auth.uid));
      allow delete: if isSignedIn() && (isAdmin() || ('studentId' in resource.data && resource.data.studentId == request.auth.uid));
    }

    // --- Workout Sessions ---
    match /workoutSessions/{sessionId} {
      allow read: if isSignedIn() && (isAdmin() || isTrainer() || ('studentId' in resource.data && resource.data.studentId == request.auth.uid));
      allow create: if isSignedIn() && (isAdmin() || ('studentId' in incoming() && incoming().studentId == request.auth.uid)) && isValidWorkoutSession(incoming());
      allow update, delete: if isAdmin();

      function isValidWorkoutSession(data) {
        return data.keys().hasAll(['workoutId', 'studentId', 'completedAt']) &&
               data.keys().size() == 3 &&
               isValidId(data.workoutId) &&
               isValidId(data.studentId) &&
               data.completedAt is timestamp;
      }
    }

    // --- Platform Plans ---
    match /platformPlans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Support Tickets ---
    match /supportTickets/{ticketId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }
    // --- Settings ---
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Security ---
    match /securityPolicies/{policyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /securityLogs/{logId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /loginHistory/{logId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /systemChanges/{changeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /blockedEntities/{entityId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Announcements ---
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Landing Pages ---
    match /landingPages/{username} {
      allow read: if true; // Public access
      allow write: if isSignedIn() && (
        isAdmin() || 
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
            (
              'username' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && (
                username.lower() == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username.lower() ||
                username.lower() == ('@' + get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username).lower() ||
                ('@' + username).lower() == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username.lower()
              )
            ) ||
            (request.auth.uid.lower() == username.lower()) ||
            (('@' + request.auth.uid).lower() == username.lower())
          )
        )
      );
    }
  }
}
